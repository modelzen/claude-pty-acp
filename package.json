{
  "name": "claude-pty-acp",
  "version": "0.1.0",
  "description": "ACP-over-PTY adapter: expose interactive Claude Code as an ACP agent so third-party clients use it while staying on the subscription billing path.",
  "type": "module",
  "bin": {
    "claude-pty-acp": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && cp src/*.mjs dist/ && chmod +x dist/index.js",
    "test:client": "node test-client.mjs",
    "test:resume": "node test-resume.mjs",
    "probe": "node probe-pty.mjs",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.0",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "acp",
    "claude",
    "claude-code",
    "agent-client-protocol",
    "pty",
    "subscription"
  ],
  "author": "Clay (ClayCheung)",
  "license": "MIT",
  "homepage": "https://github.com/modelzen/claude-pty-acp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modelzen/claude-pty-acp.git"
  },
  "bugs": {
    "url": "https://github.com/modelzen/claude-pty-acp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
